*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging outputs
build/
dist/
*.egg-info/
*.egg

# Jupyter and IPython
.ipynb_checkpoints/

# Local environment files
.env
.env.*
!.env.example

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code (local-only files and git worktrees; keep shared config trackable)
.claude/worktrees/
.claude/settings.local.json

